	(text "LMR38020 5V/2A servo PSU\n\nInput: VPP (motor rail, up to 40V)\nOutput: +5V for servo power\nfsw: ~440 kHz\nVref: 1.0V\nUVLO: ~5.8V (R25/R26)\n\nVout = 1.0 * (1 + R23/R24)\n     = 1.0 * (1 + 40.2/10)\n     = 5.02V"
		(exclude_from_sim no)
		(at 20 25 0)
		(effects
