	(text "LMR38020 3.3V/2A bridge PSU\n\nInput: bus V+ (from JBUS1/JBUS2 pin 1, 5-37V)\nOutput: +3V3 for ESP32 + SIT3088E\nfsw: ~440 kHz\nVref: 1.0V\n\nEN tied to VIN (internal UVLO ~3.7V)\n\nVout = 1.0 * (1 + R3/R4)\n     = 1.0 * (1 + 22/10)\n     = 3.20V (within ESP32 tolerance 3.0-3.6V)\n\nBoth R3 and R4 are JLCPCB basic 0402 parts."
		(at 20 25 0)
		(effects (font (size 2 2)) (justify left))
	)

	(text "NOTE: LMR38020 pinout (SOIC-8-EP) assumed:\n 1:BOOT  2:VIN  3:EN  4:RT/SYNC\n 5:FB  6:AGND  7:PGND  8:SW  9:EP->GND\nVERIFY against TI SLUSDS8 datasheet before fab."
		(at 20 65 0)
		(effects (font (size 1.27 1.27)) (justify left))
	)

